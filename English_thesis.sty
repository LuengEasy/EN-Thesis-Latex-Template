% Change the fonts and styles of chapter and section titles
\usepackage{titlesec}
% Change the chapter font and style
\titleformat{\chapter}%
    [block]%
    {\sffamily\fontsize{16pt}{19.2pt}\selectfont}%
    {Chapter \thechapter}%
    {1.0em}%
    {}%
\titlespacing{\chapter}
    {0pt}%
    {0pt}%
    {9pt}%
\titleformat{name=\chapter,numberless}%
    [block]%
    {\sffamily\fontsize{14pt}{16.8pt}\selectfont}%
    {}%
    {0pt}%
    {}%
\titlespacing{name=\chapter,numberless}
    {0pt}%
    {9pt}%
    {18pt}%
% Change the section font and style
% \titleformat*{\section}{\Large\bfseries\sffamily}
\titleformat{\section}%
    [block]%
    {\sffamily\fontsize{12pt}{14.4pt}\selectfont}%
    {\thesection}%
    {1.0em}%
    {}%
\titlespacing{\section}
    {0pt}%
    {9pt}%
    {9pt}%
\titleformat{name=\section,numberless}%
    [block]%
    {\sffamily\fontsize{14pt}{16.8pt}\selectfont}%
    {}%
    {0pt}%
    {}%
\titlespacing{name=\section,numberless}
    {0pt}%
    {0pt}%
    {9pt}%
% Change the subsection font and style
% \titleformat*{\subsection}{\large\bfseries\sffamily}
\titleformat{\subsection}%
    [block]%
    {\sffamily\fontsize{10pt}{12pt}\selectfont}%
    {\thesubsection}%
    {1.0em}%
    {}%
\titlespacing{\subsection}
    {0pt}%
    {0pt}%
    {0pt}%
% Change the subsubsection font and style
% \titleformat*{\subsubsection}{\normalsize\bfseries\sffamily}
\titleformat{\subsubsection}%
    [block]%
    {\sffamily\fontsize{10pt}{12pt}\selectfont}%
    {\thesubsubsection}%
    {1.0em}%
    {}%
\titlespacing{\subsubsection}
    {0pt}%
    {0pt}%
    {0pt}%

% Change the fonts and styles of chapter and section titles in the table of contents
\usepackage{titletoc}
\titlecontents{chapter}
[0pt] % Left spacing
{\vskip9pt\fontsize{11pt}{12pt}\selectfont} % Executed before the entry
% {\vskip8pt} % Executed before the entry
{{\thecontentslabel}\hspace{0.8em}}
{\hspace{.0em}}
{\titlerule*[0.5em]{.}\contentspage}
[\vskip 0pt] % Executed after the entry

\titlecontents{section}
[10pt] % Left spacing
{\fontsize{10pt}{12pt}\selectfont} % Executed before the entry
{{\thecontentslabel}\hspace{1.0em}}
{} % Format for unnumbered entries
{\titlerule*[0.5em]{.}\contentspage}
[\vskip 0pt] % Executed after the entry

\titlecontents{subsection}
[20pt] % Left spacing
{\fontsize{10pt}{12pt}\selectfont} % Executed before the entry
{{\thecontentslabel}\hspace{1.0em}}
{} % Format for unnumbered entries
{\titlerule*[0.5em]{.}\contentspage}
[\vskip 0pt] % Executed after the entry

