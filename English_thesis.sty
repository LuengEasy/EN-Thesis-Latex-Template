%       Thesis manuscript style file (English version)

\def\thesisyear#1{\gdef\@year{#1}}
\def\thesistitle#1{\gdef\@title{#1}}
\def\thesissupervisor#1{\gdef\@teacher{#1}}
\def\thesisdegree#1{\gdef\@degree{#1}}
\def\affiliationlineone#1{\gdef\@affiliationlineone{#1}}
\def\affiliationlinetwo#1{\gdef\@affiliationlinetwo{#1}}
\def\affiliationlinethree#1{\gdef\@affiliationlinethree{#1}}
\def\studentid#1{\gdef\@IDcode{#1}}
\def\studentname#1{\gdef\@author{#1}}

